#!/usr/bin/env ruby
# frozen_string_literal: true

require "set"
require "yaml"

ROOT = File.expand_path("..", __dir__)

PILLAR_LABELS = {
  "cprs" => "CPRS GUI",
  "bprm" => "BPRM",
  "amhg" => "VueCentric AMHG",
  "bdmg" => "VueCentric BDMG",
  "bsdx" => "VueCentric BSDX",
  "bdw" => "VueCentric BDW",
  "bhl" => "VueCentric BHL",
  "bwh" => "VueCentric BWH"
}.freeze

PILLAR_ORDER = %w[cprs amhg bdmg bsdx bdw bhl bwh bprm].freeze
DEFAULT_ENVIRONMENTS = %w[staging oroville inera jordan].freeze

def read_rpc_list(path)
  File.readlines(path, chomp: true)
      .map { |line| line.split("#", 2).first.to_s.strip }
      .reject(&:empty?)
      .to_set
end

def mapping_rpcs(path)
  return Set.new unless File.file?(path)

  File.read(path).scan(/\.rpc\s+["']([^"']+)["']/).flatten.map(&:strip).to_set
end

def namespace_for(rpc_name)
  rpc_name.to_s.split(/\s+/, 2).first.to_s.sub(/\A([A-Z]+).*\z/, "\\1")
end

def broker_dumps
  Dir.glob(File.join(ROOT, "data/broker_dumps/*.txt")).each_with_object({}) do |path, dumps|
    env = File.basename(path).sub(/_\d{8}\.txt\z/, "").sub(/\.txt\z/, "")
    dumps[env] ||= Set.new
    read_rpc_list(path).each { |line| dumps[env] << line.split("^", 2).first.strip }
  end
end

def allowlists
  Dir.glob(File.join(ROOT, "data/pillar_allowlists/*.txt")).sort.to_h do |path|
    [File.basename(path, ".txt"), read_rpc_list(path)]
  end
end

def namespace_lookup
  path = File.join(ROOT, "data/namespace_to_pillar.yml")
  return {} unless File.file?(path)

  YAML.safe_load(File.read(path), permitted_classes: [Symbol], aliases: false) || {}
end

def markdown_table(headers, rows)
  ([headers, Array.new(headers.length, "---")] + rows).map do |row|
    "| #{row.join(" | ")} |"
  end.join("\n")
end

def percent(numerator, denominator)
  return "0.0%" if denominator.zero?

  format("%.1f%%", (numerator.to_f / denominator) * 100)
end

rpms_wrapped = mapping_rpcs(File.join(ROOT, "lib/rpms_rpc/mappings.rb"))
vista_wrapped = mapping_rpcs(File.join(ROOT, "lib/vista_rpc/mappings.rb"))
vista_wrapped.merge(mapping_rpcs(File.expand_path("../../vista_rpc/mayor/rig/lib/vista_rpc/mappings.rb", ROOT)))
wrapped = rpms_wrapped | vista_wrapped
pillars = allowlists.sort_by { |key, _| PILLAR_ORDER.index(key) || PILLAR_ORDER.length }.to_h
dumps = broker_dumps
envs = (DEFAULT_ENVIRONMENTS | dumps.keys).sort_by { |env| DEFAULT_ENVIRONMENTS.index(env) || DEFAULT_ENVIRONMENTS.length }
namespace_to_pillar = namespace_lookup

headline_rows = pillars.map do |key, rpcs|
  covered = rpcs.count { |rpc| wrapped.include?(rpc) }
  [PILLAR_LABELS.fetch(key, key.upcase), rpcs.length.to_s, covered.to_s, percent(covered, rpcs.length)]
end

deduped = pillars.values.reduce(Set.new, :|)
deduped_wrapped = deduped.count { |rpc| wrapped.include?(rpc) }
headline_rows << [
  "**TOTAL (deduped)**",
  "**#{deduped.length}**",
  "**#{deduped_wrapped}**",
  "**#{percent(deduped_wrapped, deduped.length)}**"
]

namespace_pillars = Hash.new { |hash, key| hash[key] = Set.new }
pillars.each do |pillar, rpcs|
  rpcs.each { |rpc| namespace_pillars[namespace_for(rpc)] << PILLAR_LABELS.fetch(pillar, pillar.upcase) }
end

all_namespaces = (namespace_pillars.keys |
  rpms_wrapped.map { |rpc| namespace_for(rpc) } |
  vista_wrapped.map { |rpc| namespace_for(rpc) } |
  dumps.values.flat_map { |set| set.map { |rpc| namespace_for(rpc) } }).sort

detail_headers = [ "Namespace", "Wrapped (rpms-rpc)", "Wrapped (vista-rpc)", *envs, "Used by", "Status" ]
detail_rows = all_namespaces.map do |namespace|
  scoped = deduped.select { |rpc| namespace_for(rpc) == namespace }
  scoped_wrapped = scoped.count { |rpc| wrapped.include?(rpc) }
  rpms_count = rpms_wrapped.count { |rpc| namespace_for(rpc) == namespace }
  vista_count = vista_wrapped.count { |rpc| namespace_for(rpc) == namespace }
  used_by = namespace_pillars[namespace]
  used_by = Set[namespace_to_pillar.fetch(namespace, "out-of-scope")] if used_by.empty?

  env_counts = envs.map do |env|
    next "?" unless dumps.key?(env)

    dumps.fetch(env).count { |rpc| namespace_for(rpc) == namespace }.to_s
  end

  status = if scoped.empty?
             "not in 3-pillar scope"
           elsif scoped_wrapped.zero?
             "unwrapped"
           elsif scoped_wrapped == scoped.length
             "covered"
           else
             "partial (gap: #{scoped.length - scoped_wrapped})"
           end

  [namespace, rpms_count.to_s, vista_count.zero? ? "n/a" : vista_count.to_s, *env_counts, used_by.to_a.sort.join(", "), status]
end

generated = <<~MARKDOWN
  # RPC Coverage Matrix

  Generated by `bin/build_coverage_matrix`.

  This matrix tracks wrapper coverage against the three GUI replacement pillars,
  not against every RPC installed on a broker. Add one-RPC-per-line allowlists to
  `data/pillar_allowlists/` and broker dumps to `data/broker_dumps/`, then run
  `rake coverage:matrix` to refresh this document.

  ## Headline Matrix

  #{markdown_table([ "Pillar", "Allowlist size", "Wrapped", "Coverage" ], headline_rows)}

  ## Detail Matrix

  #{markdown_table(detail_headers, detail_rows)}
MARKDOWN

File.write(File.join(ROOT, "docs/RPC_COVERAGE.md"), generated)
